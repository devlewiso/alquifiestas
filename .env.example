# Alquifiestas — Environment Variables

## Copy to .env.local and fill in values

# ============================================
# SUPABASE
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ============================================
# PAGOS
# ============================================
# Stripe (USD)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# Banrural (GTQ)
BANRURAL_API_KEY=your-banrural-key
BANRURAL_MERCHANT_ID=your-merchant-id

# QPaypro (Guatemala)
QPAYPRO_API_KEY=your-qpaypro-key

# ============================================
# WHATSAPP BUSINESS API
# ============================================
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-verify-token

# ============================================
# DIALOGFLOW CX
# ============================================
DIALOGFLOW_PROJECT_ID=your-gcp-project-id
DIALOGFLOW_LOCATION=global
DIALOGFLOW_AGENT_ID=your-agent-id
GOOGLE_APPLICATION_CREDENTIALS=./path/to/service-account.json

# ============================================
# N8N (Self-hosted)
# ============================================
N8N_BASE_URL=https://n8n.neuralcodelab.com
N8N_WEBHOOK_SECRET=your-webhook-secret

# ============================================
# EXCHANGE RATE (Banguat)
# ============================================
BANGUAT_API_URL=https://www.banguat.gob.gt/inc/variables/diaria.xml
EXCHANGE_RATE_CACHE_TTL=21600

# ============================================
# APP
# ============================================
NEXT_PUBLIC_APP_URL=https://alquifiestas.com
NEXT_PUBLIC_CURRENCY_DEFAULT=GTQ
NEXT_PUBLIC_EXCHANGE_RATE_MARGIN=0.005
NODE_ENV=development

# ============================================
# EMAIL (Resend / SendGrid)
# ============================================
RESEND_API_KEY=re_xxx...
EMAIL_FROM=noreply@alquifiestas.com

# ============================================
# SENTRY (Error tracking)
# ============================================
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx
SENTRY_AUTH_TOKEN=xxx

# ============================================
# ANALYTICS
# ============================================
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
